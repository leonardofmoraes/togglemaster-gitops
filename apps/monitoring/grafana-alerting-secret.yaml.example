# NAO faca commit deste arquivo com valores reais preenchidos.
# Copie para grafana-alerting-secret.yaml, preencha as chaves reais
# (PagerDuty Integration Key e URL do webhook do Slack) e aplique
# manualmente com kubectl no dia da gravacao.
apiVersion: v1
kind: Secret
metadata:
  name: grafana-alerting-provisioning
  namespace: monitoring
type: Opaque
stringData:
  contactpoints.yaml: |
    apiVersion: 1
    contactPoints:
      - orgId: 1
        name: pagerduty-auth-critical
        receivers:
          - uid: pagerduty1
            type: pagerduty
            settings:
              integrationKey: "<PAGERDUTY_INTEGRATION_KEY>"
              severity: critical
      - orgId: 1
        name: slack-chatops
        receivers:
          - uid: slack1
            type: slack
            settings:
              url: "<SLACK_WEBHOOK_URL>"
              title: "{{ template \"default.title\" . }}"
              text: "{{ template \"default.message\" . }}"

  policies.yaml: |
    apiVersion: 1
    policies:
      - orgId: 1
        receiver: slack-chatops
        group_by: ["alertname"]
        routes:
          - receiver: pagerduty-auth-critical
            object_matchers:
              - ["service", "=", "auth-service"]
            continue: true
          - receiver: slack-chatops
            object_matchers:
              - ["service", "=", "auth-service"]

  rules.yaml: |
    apiVersion: 1
    groups:
      - orgId: 1
        name: togglemaster-alerts
        folder: ToggleMaster
        interval: 1m
        rules:
          - uid: auth-5xx-rate
            title: "Auth Service - Taxa de erro 5xx acima de 5%"
            condition: C
            for: 2m
            labels:
              service: auth-service
              severity: critical
            annotations:
              summary: "Taxa de erro 5xx do auth-service acima de 5%"
            data:
              - refId: A
                relativeTimeRange:
                  from: 300
                  to: 0
                datasourceUid: prometheus
                model:
                  refId: A
                  expr: |
                    100 * sum(rate(http_server_duration_milliseconds_count{service_name="auth-service", http_status_code=~"5.."}[5m]))
                    /
                    sum(rate(http_server_duration_milliseconds_count{service_name="auth-service"}[5m]))
              - refId: C
                datasourceUid: "__expr__"
                model:
                  type: threshold
                  expression: A
                  conditions:
                    - evaluator:
                        type: gt
                        params: [5]